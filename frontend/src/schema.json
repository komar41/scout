{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Grammar (Physical/View/Join/Interaction/Choice)",
  "type": "object",
  "additionalProperties": false,

  "oneOf": [
    { "required": ["physical_layer"] },
    { "required": ["view"] },
    { "required": ["join"] },
    { "required": ["transformation"] },
    { "required": ["interaction"] },
    { "required": ["choice"] }
  ],
  "minProperties": 1,
  "maxProperties": 1,

  "properties": {
    "physical_layer": { "$ref": "#/$defs/physical_layer" },

    "view": { "$ref": "#/$defs/view" },
    "join": { "$ref": "#/$defs/join" },
    "transformation": { "$ref": "#/$defs/transformation" },
    "interaction": { "$ref": "#/$defs/interaction" },
    "choice": { "$ref": "#/$defs/choice" }
  },

  "$defs": {
    "physical_layer": {
      "type": "object",
      "required": ["id", "datafile", "region_of_interest", "layers"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "datafile": { "type": "string", "minLength": 1 },
        "region_of_interest": {
          "type": "object",
          "required": ["type", "value"],
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["bbox", "geojson"] },
            "value": {}
          },
          "allOf": [
            {
              "if": { "properties": { "type": { "const": "bbox" } } },
              "then": {
                "properties": {
                  "value": {
                    "type": "array",
                    "minItems": 4,
                    "maxItems": 4,
                    "items": [
                      { "type": "number", "minimum": -180, "maximum": 180 },
                      { "type": "number", "minimum": -90, "maximum": 90 },
                      { "type": "number", "minimum": -180, "maximum": 180 },
                      { "type": "number", "minimum": -90, "maximum": 90 }
                    ]
                  }
                }
              }
            },
            {
              "if": { "properties": { "type": { "const": "geojson" } } },
              "then": {
                "properties": {
                  "value": { "type": "string", "pattern": "\\.geojson$" }
                }
              }
            }
          ]
        },
        "layers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["tag"],
            "additionalProperties": false,
            "properties": {
              "tag": { "type": "string", "minLength": 1 },
              "features": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "uniqueItems": false
              }
            }
          }
        }
      }
    },

    "view": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "physical_layer",
              "type",
              "projection",
              "zoom_pan",
              "layers"
            ],
            "not": { "required": ["thematic_layer"] },
            "properties": {
              "physical_layer": {
                "type": "object",
                "required": ["ref"],
                "additionalProperties": false,
                "properties": {
                  "ref": { "type": "string", "minLength": 1 }
                }
              },
              "type": { "type": "string" },
              "projection": { "type": "string" },
              "zoom_pan": { "type": "boolean" },
              "layers": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "required": ["tag", "style"],
                  "additionalProperties": true,
                  "properties": {
                    "tag": { "type": "string", "minLength": 1 },
                    "style": { "type": "object" }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["thematic_layer", "type", "style"],
            "not": { "required": ["physical_layer"] },
            "properties": {
              "thematic_layer": {
                "type": "object",
                "required": ["ref"],
                "additionalProperties": false,
                "properties": {
                  "ref": { "type": "string", "minLength": 1 }
                }
              },
              "type": { "type": "string" },
              "style": { "type": "object" }
            }
          }
        ]
      }
    },
    "join": false,
    "transformation": false,
    "interaction": false,
    "choice": false
  }
}
