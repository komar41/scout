{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Physical Layer Schema",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "id",
    "type",
    "file_type",
    "datafile",
    "region_of_interest",
    "layers"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "type": { "type": "string", "enum": ["raster", "vector"] },
    "file_type": { "type": "string" },
    "datafile": { "type": "string", "minLength": 1 },
    "region_of_interest": {
      "type": "object",
      "required": ["type", "value"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["bbox", "geojson"] },
        "value": {}
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "bbox" } } },
          "then": {
            "properties": {
              "value": {
                "type": "array",
                "minItems": 4,
                "maxItems": 4,
                "items": [
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 },
                  { "type": "number", "minimum": -180, "maximum": 180 },
                  { "type": "number", "minimum": -90, "maximum": 90 }
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "geojson" } } },
          "then": {
            "properties": {
              "value": { "type": "string", "pattern": "\\.geojson$" }
            }
          }
        }
      ]
    },
    "layers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tag", "geom-type"],
        "additionalProperties": false,
        "properties": {
          "tag": { "type": "string", "minLength": 1 },
          "geom-type": {
            "type": "string",
            "enum": ["polygon", "multipolygon", "linestring", "point"]
          },
          "features": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 },
            "uniqueItems": false
          }
        }
      }
    }
  }
}
