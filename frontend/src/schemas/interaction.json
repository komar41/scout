{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Interaction Schema",
  "type": "object",
  "oneOf": [
    {
      "description": "Click → remove feature(s) from a given physical layer + tag.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "action", "physicalLayerRef", "layer"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["click"]
        },
        "action": {
          "type": "string",
          "enum": ["remove"]
        },
        "physicalLayerRef": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag"],
          "properties": {
            "tag": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "description": "Click → modify a specific feature/attribute on a given tag.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "action", "physicalLayerRef", "layer"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["click"]
        },
        "action": {
          "type": "string",
          "enum": ["modify_feature"]
        },
        "physicalLayerRef": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag", "feature"],
          "properties": {
            "tag": { "type": "string", "minLength": 1 },
            "feature": {
              "type": "string",
              "minLength": 1,
              "description": "Name of the attribute to modify, e.g. 'height'."
            }
          }
        }
      }
    },
    {
      "description": "Hover → highlight geometries for a given tag.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "action", "physicalLayerRef", "layer"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hover"]
        },
        "action": {
          "type": "string",
          "enum": ["highlight"]
        },
        "physicalLayerRef": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag"],
          "properties": {
            "tag": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    {
      "description": "Hover → highlight + show text (e.g., from a feature) for a given tag.",
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "action", "physicalLayerRef", "layer"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["hover"]
        },
        "action": {
          "type": "string",
          "enum": ["highlight+show"]
        },
        "physicalLayerRef": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "object",
          "additionalProperties": false,
          "required": ["tag"],
          "properties": {
            "tag": { "type": "string", "minLength": 1 },
            "feature": {
              "type": "string",
              "minLength": 1,
              "description": "Attribute to display on hover, e.g. 'height'."
            }
          }
        }
      }
    }
  ]
}
