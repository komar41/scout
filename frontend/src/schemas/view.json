{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "View Schema",

  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "oneOf": [
      {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "physical_layer",
          "type",
          "zoom_pan",
          "layers"
        ],
        "not": { "required": ["thematic_layer"] },
        "properties": {
          "physical_layer": {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": false,
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          },
          "type": { "type": "string" },
          "zoom_pan": { "type": "boolean" },
          "layers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["tag", "style"],
              "additionalProperties": true,
              "properties": {
                "tag": { "type": "string", "minLength": 1 },
                "style": { "type": "object" }
              }
            }
          }
        }
      },
      {
        "type": "object",
        "additionalProperties": false,
        "required": ["thematic_layer", "type", "style"],
        "not": { "required": ["physical_layer"] },
        "properties": {
          "thematic_layer": {
            "type": "object",
            "required": ["ref"],
            "additionalProperties": false,
            "properties": {
              "ref": { "type": "string", "minLength": 1 }
            }
          },
          "type": { "type": "string" },
          "style": { "type": "object" }
        }
      }
    ]
  }
}
